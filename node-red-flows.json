    {
        "id": "csvStore",
        "type": "function",
        "z": "f6f2187d.f17ca8",
        "name": "guardar en contexto",
        "func": "let p = msg.payload;\nif (Buffer.isBuffer(p)) p = p.toString();\nif (typeof p === \"string\") { try { p = JSON.parse(p); } catch (e) { /* alerta es texto plano */ } }\nconst t = msg.topic || \"\";\nif (t.endsWith(\"/temperatura\") && p && p.temperatura !== undefined) flow.set(\"temperatura\", p.temperatura);\nelse if (t.endsWith(\"/humedad\") && p && p.humedad !== undefined) flow.set(\"humedad\", p.humedad);\nelse if (t.endsWith(\"/presion\") && p && p.presion !== undefined) flow.set(\"presion\", p.presion);\nelse if (t.endsWith(\"/sensor_extra\") && p && p.sensor_extra !== undefined) flow.set(\"sensor_extra\", p.sensor_extra);\nelse if (t.endsWith(\"/alerta\")) { flow.set(\"alerta_text\", typeof p === \"string\" ? p : JSON.stringify(p)); flow.set(\"alerta_time\", Date.now()); }\nreturn null;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
