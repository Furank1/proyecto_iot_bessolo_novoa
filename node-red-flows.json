        "type": "function",
        "z": "f6f2187d.f17ca8",
        "name": "armar registro",
        "func": "const temperatura = flow.get(\"temperatura\");\nconst humedad = flow.get(\"humedad\");\nconst presion = flow.get(\"presion\");\nconst sensor_extra = flow.get(\"sensor_extra\");\n// no escribir fila si todavia no llego ningun dato de sensores\nif (temperatura === undefined && humedad === undefined && presion === undefined && sensor_extra === undefined) {\n    return null;\n}\nconst at = flow.get(\"alerta_time\") || 0;\nconst alerta = (Date.now() - at < 15000) ? (flow.get(\"alerta_text\") || \"normal\") : \"normal\";\nconst pt = flow.get(\"persona_time\") || 0;\nconst persona = (Date.now() - pt < 15000) ? (flow.get(\"persona_text\") || \"ninguna\") : \"ninguna\";\nmsg.payload = {\n    timestamp: new Date().toISOString(),\n    temperatura: temperatura,\n    humedad: humedad,\n    presion: presion,\n    sensor_extra: sensor_extra,\n    alerta: alerta,\n    persona: persona\n};\nreturn msg;",
