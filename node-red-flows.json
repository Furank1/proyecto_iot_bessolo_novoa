    {
        "id": "4640e9bf00ce4c5a",
        "type": "function",
        "z": "f6f2187d.f17ca8",
        "name": "check persona",
        "func": "const personas = msg.payload.filter(d => d.class === 'person' && d.score > 0.7);\n\nif (personas.length > 0) {\n    msg.payload = \"SI - \" + Math.round(personas[0].score * 100) + \"%\";\n    msg.detectado = true;\n} else {\n    msg.payload = \"NO\";\n    msg.detectado = false;\n}\nreturn msg;\n",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 860,
        "y": 660,
        "wires": [
            [
                "7d80d6aa8b67d42f",
                "979f68a115d79579"
            ]
