    {
        "id": "f1fn01",
        "type": "function",
        "z": "f6f2187d.f17ca8",
        "name": "filtrar + notificar",
        "func": "const r = msg.payload;\nlet dashText;\nlet telegramMsg = null;\n\nif (!r.persona || r.nombre === \"sin_cara\") {\n    dashText = \"sin cara\";\n} else if (r.nombre === \"desconocido\") {\n    dashText = \"desconocido\";\n} else {\n    // persona conocida\n    dashText = r.nombre + \" (\" + r.confianza + \"%)\";\n    flow.set(\"persona_text\", r.nombre);\n    flow.set(\"persona_time\", Date.now());\n    const ahora = Date.now();\n    const COOLDOWN = 60000; // 60s por persona para no spamear\n    const last = flow.get(\"notif_\" + r.nombre) || 0;\n    if (ahora - last >= COOLDOWN) {\n        flow.set(\"notif_\" + r.nombre, ahora);\n        const ts = new Date().toLocaleString(\"es-CL\");\n        telegramMsg = {\n            headers: { \"Content-Type\": \"application/json\" },\n            payload: {\n                chat_id: 0,\n                text: \"ALERTA SmartHome\\nEvento: persona detectada\\nPersona: \" + r.nombre +\n                      \" (\" + r.confianza + \"%)\\nHora: \" + ts\n            }\n        };\n    }\n}\n\nreturn [telegramMsg, { payload: dashText }];",
        "outputs": 2,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
